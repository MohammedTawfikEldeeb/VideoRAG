# Large user data — never needed in build context
videos/
clips/
runtime/
data/
cache_*/

# Application state volumes
.pixeltable/
.records/

# Python cache
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
.venv/
venv/

# Environment secrets
.env
.env.*
!.env.example

# Git / IDE / tooling
.git/
.gitignore
.claude/
.python-version

# Video/media files anywhere in project
*.mp4
*.avi
*.mov
*.mkv
*.webm
*.flv
*.wmv
